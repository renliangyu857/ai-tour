# =============================================
# TourismRAG 环境变量配置模板
# 复制此文件为 .env 并填写真实值
# =============================================

# ---- 阿里云 DashScope (Qwen) ----
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=tourism_root_2024
MYSQL_DATABASE=tourism_rag
MYSQL_USER=tourism
MYSQL_PASSWORD=tourism_pass_2024

# ---- Milvus ----
MILVUS_HOST=milvus
MILVUS_PORT=19530

# ---- 应用端口 ----
BACKEND_PORT=8080
FRONTEND_PORT=3000

# =============================================
# 智能行程 Agent 配置
# 以下配置为空时自动使用 Mock 数据，本地演示无需配置
# =============================================

# ---- 高德地图 API（同时用于地图、POI 搜索和天气预报）----
# 免费注册：https://lbs.amap.com/
# 空值=使用内置精选 POI、美食和模拟天气数据
MAP_API_KEY=

# ---- Agent 运行参数 ----
AGENT_ENABLED=true
AGENT_TIMEOUT_MS=8000
AGENT_MAX_STEPS=10
FOOD_MIN_RATING=4.0

# =============================================
# 多智能体协作系统 (v2.0 新增)
# =============================================

# 是否启用多智能体模式
MULTI_AGENT_ENABLED=true

# SSE 流式超时（毫秒）
MULTI_AGENT_STREAM_TIMEOUT=120000

# 是否启用智能体辩论
MULTI_AGENT_DEBATE_ENABLED=true
